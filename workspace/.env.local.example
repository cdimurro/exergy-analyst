# Workspace AI Configuration
# Copy this to .env.local and add your API keys
#
# Required for AI assistant (chat, analysis, recommendations):
DEEPSEEK_API_KEY=your_deepseek_api_key_here
EXERGY_AGENT_MODEL=deepseek-v4-flash

# Required in production for Auth.js session signing.
# Local development has a built-in fallback so anonymous use still works.
AUTH_SECRET=replace_with_a_long_random_secret
# Optional Auth.js compatibility alias. AUTH_SECRET takes precedence.
NEXTAUTH_SECRET=

# Optional fast complex-PDF vision assistant. The agent tries this before
# local MinerU when EXERGY_PDF_VISION_PROVIDER=auto.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-3.5-flash
EXERGY_PDF_VISION_PROVIDER=auto
EXERGY_GEMINI_PDF_MAX_MB=20
EXERGY_GEMINI_PDF_TIMEOUT_SECONDS=120
EXERGY_GEMINI_PDF_MAX_OUTPUT_TOKENS=12000
# Set to 1 only when you want to force local MinerU/local PDF extraction.
EXERGY_DISABLE_GEMINI_PDF_VISION=false

# Optional environmental site-data providers. The backend also reads
# /mnt/c/Users/Chris/nature-engine/config/.env and
# /home/chris/nature-engine/config/.env by default when present.
CDS_API_KEY=
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=
FIRMS_MAP_KEY=
GBIF_USERNAME=
GBIF_PASSWORD=
GBIF_EMAIL=

# Optional: high-accuracy complex PDF/table extraction through local MinerU 2.5 Pro.
# Defaults auto-detect the Breakthrough Engine local venv when present.
EXERGY_BREAKTHROUGH_ENGINE_ROOT=/home/chris/breakthrough-engine
EXERGY_MINERU_PYTHON=/home/chris/breakthrough-engine/.venv/bin/python
EXERGY_MINERU_BACKEND=vlm-auto-engine
EXERGY_MINERU_TIMEOUT_SECONDS=900
MINERU_USE_OCR=true
MINERU_ENABLE_TABLE=true
MINERU_ENABLE_FORMULA=false
# Set to 1 only in fast tests where local OCR should be skipped.
EXERGY_DISABLE_MINERU=false

# Optional local backend overrides. Defaults assume the repo root is one
# directory above workspace/ and Python lives in .venv/bin/python.
ENGINE_ROOT=
PYTHON_PATH=

# Agent workspace sandbox. Use container mode for real client workloads.
# Build the image with: npm run sandbox:build
EXERGY_AGENT_SANDBOX_MODE=container
EXERGY_AGENT_CONTAINER_RUNTIME=docker
EXERGY_AGENT_CONTAINER_IMAGE=exergy-agent-workspace:2026-05-24
EXERGY_AGENT_CONTAINER_PULL_POLICY=never
EXERGY_AGENT_ALLOW_NETWORK=false
EXERGY_AGENT_ALLOW_DEPENDENCY_INSTALL=true
EXERGY_AGENT_ALLOWED_PIP_PACKAGES=numpy,pandas,scipy,matplotlib,seaborn,scikit-learn,statsmodels,sympy,requests,beautifulsoup4,lxml,openpyxl,xlsxwriter,reportlab,pillow,pymupdf,pypdf,pvlib,coolprop,thermo,tabulate,networkx
EXERGY_AGENT_MEMORY_MB=2048
EXERGY_AGENT_CPU_SECONDS=300
EXERGY_AGENT_MAX_FILE_MB=100
EXERGY_AGENT_MAX_OUTPUT_FILES=80
EXERGY_AGENT_MAX_INPUT_FILES=20

# Exergy Lab Nature explorer. Use the deployed nature-engine URL when the
# FastAPI dashboard is hosted separately, e.g. https://.../nature/explorer.
NEXT_PUBLIC_NATURE_ENGINE_EXPLORE_URL=/nature/explorer
